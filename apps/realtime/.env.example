PORT=4001

# Must match apps/web's REALTIME_JWT_SECRET.
REALTIME_JWT_SECRET="generate-with: openssl rand -base64 32"

# apps/web's URL — this service calls back into it to persist chat messages.
WEB_INTERNAL_URL="http://localhost:3000"

# Browser-facing apps/web URL, used for the Socket.io CORS origin.
WEB_PUBLIC_URL="http://localhost:3000"
